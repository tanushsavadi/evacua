# Supabase backend used by the responder dashboard.
# Schema: run supabase/fire-ops.sql and supabase/voice-agent.sql in the SQL editor.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: force bundled responder demo data even when Supabase is configured.
# When Supabase env vars are omitted, demo data is used automatically.
# Set to false to make missing Supabase config fail loudly instead.
EVACUA_DEMO_MODE=
# Client-side mirror of EVACUA_DEMO_MODE (used when the flag must be visible
# to browser code; keep the two in sync).
NEXT_PUBLIC_EVACUA_DEMO_MODE=

# Optional server-side key for write-heavy responder operations.
# If unset, the API uses NEXT_PUBLIC_SUPABASE_ANON_KEY.
SUPABASE_SERVICE_ROLE_KEY=

# User-Agent string required by OSM Nominatim geocoding (be a good citizen)
NOMINATIM_UA="Evacua/0.1 (https://evacua.app)"

# Mapbox token for the detailed 3D responder map, terrain/buildings, and
# road-following responder routes. No token is bundled: if unset, the map
# panel shows a "map source unavailable" state and dispatch falls back to
# straight-line geometry.
NEXT_PUBLIC_MAPBOX_TOKEN=
# Optional server-side Mapbox token for the Directions API (route geometry).
# Falls back to NEXT_PUBLIC_MAPBOX_TOKEN when unset. Also read by the
# python-agent fire monitor.
MAPBOX_ACCESS_TOKEN=

# Alert dispatch is DRY-RUN by default: /api/send-emergency-alert prepares
# alert drafts without sending anything. Set EVACUA_ALERT_MODE=live to
# actually dispatch through the configured channels below.
EVACUA_ALERT_MODE=

# Optional alert dispatch channel. If unset, Evacua falls back to generating
# alert text for manual send.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional custom dispatch webhooks for additional channels.
# Evacua POSTs a JSON payload with message + recipients.
SMS_WEBHOOK_URL=
EMAIL_WEBHOOK_URL=

# Set to "true" to require a matching pending-action approval token before
# any live action (alert, dispatch, route/evacuation write) executes.
# When unset, dashboard-initiated actions are allowed without a token.
EVACUA_REQUIRE_APPROVAL_TOKEN=

# Evacua assistant intelligence and voice transport.
# ANTHROPIC_MODEL defaults to claude-opus-4-7 in code when omitted.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7
# Optional model override for the assistant-suggestions route
# (defaults to claude-sonnet-4-5).
ANTHROPIC_SUGGESTIONS_MODEL=
# Optional overrides for voice intent classification:
# EVACUA_VOICE_INTENT_MODEL=llm enables LLM intent parsing;
# EVACUA_VOICE_INTENT_MODEL_NAME picks the model (defaults to ANTHROPIC_MODEL).
EVACUA_VOICE_INTENT_MODEL=
EVACUA_VOICE_INTENT_MODEL_NAME=

# Vapi browser voice session.
NEXT_PUBLIC_VAPI_PUBLIC_KEY=
NEXT_PUBLIC_VAPI_ASSISTANT_ID=
# Shared secret for the /api/vapi/events webhook. When unset the endpoint
# accepts unauthenticated events — set this in any deployed environment.
EVACUA_VAPI_WEBHOOK_TOKEN=

# Base URL the python-agent fire monitor uses to reach this app.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Set to "true" to log fire-state API debug output on the server.
EVACUA_DEBUG_API=
